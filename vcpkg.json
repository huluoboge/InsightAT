{
  "name": "insightat",
  "version": "0.2.0",
  "description": "InsightAT is an open-source one-stop Structure-from-Motion system designed for easy-to-use and automated 3D reconstruction.",
  "homepage": "https://github.com/huluoboge/InsightAT",
  "license": "MIT",
  "supports": "windows & x64",
  "dependencies": [
    {
      "name": "ceres",
      "features": [
        "lapack",
        "schur",
        "suitesparse"
      ]
    },
    "cuda",
    "egl",
    "eigen3",
    "gflags",
    "glew",
    "glog",
    {
      "name": "gdal",
      "default-features": false,
      "features": [
        "curl",
        "expat",
        "geos",
        "jpeg",
        "png",
        "sqlite3"
      ]
    },
    "nlohmann-json",
    {
      "name": "opencv4",
      "default-features": false,
      "features": [
        "jpeg",
        "png",
        "tiff"
      ]
    },
    {
      "name": "qt5-base",
      "default-features": false
    },
    {
      "name": "vcpkg-cmake",
      "host": true
    },
    {
      "name": "vcpkg-cmake-config",
      "host": true
    }
  ],
  "overrides": [
    {
      "name": "metis",
      "version": "2022-07-27"
    },
    {
      "name": "gklib",
      "version": "2023-03-27"
    }
  ],
  "default-features": []
}
