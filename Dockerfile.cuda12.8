# ─── InsightAT CUDA 12.8 + cuDSS Docker Build ─────────────────────────────────
#
# Builds InsightAT with CUDA-accelerated Ceres Solver (huluoboge/ceres-solver hy
# branch, with cuDSS sparse Cholesky support) and packages the result as an
# AppImage — all inside the container.
#
# Base: nvidia/cuda:12.8.0-devel-ubuntu22.04
#   - Ubuntu 22.04 (glibc 2.35) → best AppImage compatibility before glibc
#     becomes too new for older distros.
#   - CUDA 12.8 toolkit + cuDSS (NVIDIA apt repo)
#
# Usage:
#   docker build -t insightat:cuda12.8 -f Dockerfile.cuda12.8 .
#   docker run --rm --gpus all -it insightat:cuda12.8
#
# Extract AppImage:
#   docker create --name insightat-tmp insightat:cuda12.8
#   docker cp insightat-tmp:/workspace/insightat/build-appimage-cuda12.8 ./
#   docker rm insightat-tmp
#
# ─────────────────────────────────────────────────────────────────────────────

FROM nvidia/cuda:12.8.0-devel-ubuntu22.04

ENV DEBIAN_FRONTEND=noninteractive \
    TZ=UTC \
    CUDA_HOME=/usr/local/cuda \
    PATH=/usr/local/cuda/bin:${PATH} \
    LD_LIBRARY_PATH=/usr/local/cuda/lib64:${LD_LIBRARY_PATH}

WORKDIR /workspace/insightat

# ── System dependencies ──────────────────────────────────────────────────────
# NOTE: libceres-dev from apt is intentionally excluded — we build a custom
# Ceres with CUDA+cuDSS support from huluoboge/ceres-solver hy branch.
# cuDSS is installed from NVIDIA's CUDA 12.8 apt repository.
RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    ca-certificates \
    git \
    python3 \
    python3-pip \
    libeigen3-dev \
    libgflags-dev \
    libgoogle-glog-dev \
    libopencv-dev \
    libgdal-dev \
    libglew-dev \
    libegl1-mesa-dev \
    libopengl0 \
    libsuitesparse-dev \
    libmetis-dev \
    libtbb-dev \
    libopenblas-dev \
    liblapack-dev \
    liblapacke-dev \
    libboost-filesystem-dev \
    libboost-program-options-dev \
    libboost-system-dev \
    qtbase5-dev \
    libqt5opengl5-dev \
    p7zip-full \
    wget \
    file \
    fuse \
    libfuse2 \
    && rm -rf /var/lib/apt/lists/* \
    && pip3 install --no-cache-dir "cmake>=3.24" \
    && cmake --version

# ── cuDSS (NVIDIA CUDA Direct Sparse Solver) ──────────────────────────────
# Install from local repo .deb (the user provided cudss-local-repo-... .deb).
# This repo provides libcudss-dev headers + shared libs needed by Ceres.
COPY cudss-local-repo-ubuntu2204-0.7.1_0.7.1-1_amd64.deb /tmp/cudss-local-repo.deb
RUN dpkg -i /tmp/cudss-local-repo.deb \
    && cp /var/cudss-local-repo-ubuntu2204-0.7.1/cudss-*-keyring.gpg /usr/share/keyrings/ \
    && apt-get update \
    && apt-get install -y --no-install-recommends cudss \
    && rm -rf /var/lib/apt/lists/* /tmp/cudss-local-repo.deb

# ── Custom Ceres-Solver (CUDA 12 + cuDSS) ────────────────────────────────────
# Fork:   https://github.com/huluoboge/ceres-solver (hy branch)
# Script: build_cuda12.sh — configures cmake with CUDA 12.x flags + cuDSS.
# We run the script, then install to /usr/local so InsightAT's find_package
# picks it up automatically.
RUN git clone --branch hy --depth 1 --recurse-submodules https://github.com/huluoboge/ceres-solver.git /tmp/ceres-solver \
    && cd /tmp/ceres-solver \
    && chmod +x build_cuda12.sh \
    && ./build_cuda12.sh \
    && cd build_cuda128 \
    && make install \
    && rm -rf /tmp/ceres-solver

# Verify Ceres and abseil are findable
RUN echo "CeresConfig: $(find /root -name CeresConfig.cmake 2>/dev/null)" \
    && echo "abslConfig:  $(find /root -name abslConfig.cmake 2>/dev/null)"

# ── Build InsightAT ──────────────────────────────────────────────────────────
COPY . .

ARG CMAKE_CUDA_ARCHITECTURES="60;61;70;75;80;86;89;90-virtual"
RUN cmake -S . -B build-ceres-12.8 \
    -DCMAKE_BUILD_TYPE=Release \
    -DCMAKE_CUDA_ARCHITECTURES="${CMAKE_CUDA_ARCHITECTURES}" \
    -DCeres_DIR="$HOME/.local/ceres-cuda128/lib/cmake/Ceres" \
    -Dcudss_DIR="/usr/lib/x86_64-linux-gnu/libcudss/12/cmake/cudss" \
    -DSIFTGPU_ENABLE_CUDA=OFF \
    && cmake --build build-ceres-12.8 -j"$(nproc)"

# Smoke test: CLI loads (no GPU work)
RUN build-ceres-12.8/isat_project --help 2>&1 | head -5 && echo "Smoke test OK"

# ── Package AppImage ─────────────────────────────────────────────────────────
ENV INSIGHTAT_BUILD_DIR=/workspace/insightat/build-ceres-12.8 \
    CUDA_LIBS_DIR=/usr/local/cuda-12.8/lib64 \
    VERSION=0.2.5-cuda12.8 \
    APPIMAGE_OUT_DIR=/workspace/insightat/build-appimage-cuda12.8 \
    APPIMAGE_EXTRACT_AND_RUN=1

# Use ./ prefix so BASH_SOURCE resolves the directory correctly
RUN cd /workspace/insightat && bash ./compile_appimage-12.8.sh

CMD ["/bin/bash"]
